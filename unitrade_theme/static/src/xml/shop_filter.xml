<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="unitrade_theme.ShopFilter">
        <div class="row o_wsale_products_main_row align-items-start flex-nowrap tw-w-full tw-max-w-[1200px] tw-mx-auto tw-m-0 tw-px-0 md:tw-px-4">
            <aside id="products_grid_before" class="d-none d-lg-block col-3 px-3 clearfix">
                <div class="tw-bg-white tw-rounded-[14px] tw-p-[24px] tw-w-full tw-shadow-sm tw-border tw-border-solid tw-border-gray-200">
                    <div class="tw-flex tw-items-center tw-justify-between tw-mb-8">
                        <h5 class="tw-font-['Urbanist'] tw-font-bold tw-text-[20px] tw-text-[#1a1a1a] tw-m-0">Filter</h5>
                        <button type="button" t-on-click="resetFilters" class="tw-border tw-border-gray-300 tw-bg-transparent tw-px-4 tw-py-1.5 tw-rounded-full tw-font-['Urbanist'] tw-text-[13px] tw-text-[#b3b3b3] hover:tw-text-black hover:tw-border-black tw-transition-colors tw-cursor-pointer">Reset filters</button>
                    </div>

                    <div class="tw-mb-8">
                        <h6 class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-[#4a4a4a] tw-mb-3 tw-text-left">Lokasi</h6>
                        <div class="tw-bg-[#fafafa] tw-p-[4px] tw-rounded-full tw-flex tw-items-center tw-w-full tw-min-h-[44px]" id="ut-lokasi-group">
                            <div t-att-class="pillClass('lokasi', 'terdekat')" data-group="lokasi" data-value="terdekat" t-on-click="() => this.togglePill('lokasi', 'terdekat')">
                                <t t-esc="state.geoLoading ? 'Mencari' : 'Terdekat'"/>
                            </div>
                            <div t-att-class="pillClass('lokasi', 'kabupaten')" data-group="lokasi" data-value="kabupaten" t-on-click="() => this.togglePill('lokasi', 'kabupaten')">Kabupaten</div>
                            <div t-att-class="pillClass('lokasi', 'diy')" data-group="lokasi" data-value="diy" t-on-click="() => this.togglePill('lokasi', 'diy')">DIY</div>
                        </div>
                        <input type="hidden" name="lokasi" id="ut-lokasi-val" t-att-value="state.lokasi"/>
                    </div>

                    <div class="tw-mb-8">
                        <h6 class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-[#4a4a4a] tw-mb-8 tw-text-left">Harga</h6>
                        <div class="tw-relative tw-w-full tw-mb-4" style="height: 50px;">
                            <div style="position:absolute; top:50%; transform:translateY(-50%); width:100%; height:10px; background:#f0f0f0; border-radius:999px; z-index:1; pointer-events:none;"></div>
                            <div id="slider-track" t-att-style="trackStyle"></div>
                            <div id="min-tooltip" class="tw-bg-black tw-text-white tw-px-3 tw-py-1 tw-rounded-full tw-font-['Urbanist'] tw-font-bold tw-text-[11px]" t-att-style="minTooltipStyle">
                                <t t-esc="formatK(state.minK)"/>
                            </div>
                            <div id="max-tooltip" class="tw-bg-black tw-text-white tw-px-3 tw-py-1 tw-rounded-full tw-font-['Urbanist'] tw-font-bold tw-text-[11px]" t-att-style="maxTooltipStyle">
                                <t t-esc="formatK(state.maxK)"/>
                            </div>
                            <input type="range" id="min-price" min="0" max="5000" t-att-value="state.minK" step="10" class="custom-range-slider" style="position:absolute; top:50%; transform:translateY(-50%); width:100%; height:10px; -webkit-appearance:none; appearance:none; background:transparent; pointer-events:none; z-index:10; margin:0; outline:none;" t-on-input="onMinInput"/>
                            <input type="range" id="max-price" min="0" max="5000" t-att-value="state.maxK" step="10" class="custom-range-slider" style="position:absolute; top:50%; transform:translateY(-50%); width:100%; height:10px; -webkit-appearance:none; appearance:none; background:transparent; pointer-events:none; z-index:11; margin:0; outline:none;" t-on-input="onMaxInput"/>
                            <input type="hidden" name="min_price" id="odoo-min-price" t-att-value="state.minK * 1000"/>
                            <input type="hidden" name="max_price" id="odoo-max-price" t-att-value="state.maxK * 1000"/>
                        </div>
                        <style>
                            .custom-range-slider::-webkit-slider-runnable-track { background:transparent; height:10px; }
                            .custom-range-slider::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; pointer-events:auto; width:18px; height:18px; background:#000; border-radius:50%; cursor:pointer; border:none; position:relative; z-index:50; margin-top:-4px; }
                            .custom-range-slider::-moz-range-track { background:transparent; height:10px; border:none; }
                            .custom-range-slider::-moz-range-thumb { pointer-events:auto; width:18px; height:18px; background:#000; border-radius:50%; cursor:pointer; border:none; }
                            .ut-pill { flex:1 1 0; min-width:0; height:36px; display:flex; align-items:center; justify-content:center; text-align:center; padding:0 8px; border-radius:999px; font-family:'Urbanist',sans-serif; font-size:13px; line-height:1; white-space:nowrap; cursor:pointer; transition:all 0.2s ease; user-select:none; }
                            .ut-pill-inactive { color:#b3b3b3; font-weight:500; background:transparent; }
                            .ut-pill-active { color:#1a1a1a; font-weight:700; background:#fff; box-shadow:0 2px 8px rgba(0,0,0,0.06); }
                            .ut-pill-loading { font-size:12px; }
                        </style>
                    </div>

                    <div class="tw-mb-10">
                        <h6 class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-[#4a4a4a] tw-mb-3 tw-text-left">Kondisi</h6>
                        <div class="tw-bg-[#fafafa] tw-p-[4px] tw-rounded-full tw-flex tw-items-center tw-w-[75%]" id="ut-kondisi-group">
                            <div t-att-class="pillClass('kondisi', 'baru')" data-group="kondisi" data-value="baru" t-on-click="() => this.togglePill('kondisi', 'baru')">Baru</div>
                            <div t-att-class="pillClass('kondisi', 'bekas')" data-group="kondisi" data-value="bekas" t-on-click="() => this.togglePill('kondisi', 'bekas')">Bekas</div>
                        </div>
                        <input type="hidden" name="kondisi" id="ut-kondisi-val" t-att-value="state.kondisi"/>
                    </div>

                    <div class="tw-flex tw-items-center tw-gap-3">
                        <button type="button" t-on-click="applyFilters" t-att-disabled="state.loading" class="tw-flex-1 tw-bg-black tw-text-white tw-py-[12px] tw-rounded-full tw-font-['Urbanist'] tw-font-bold tw-text-[15px] hover:tw-bg-[#333] tw-transition-colors tw-cursor-pointer tw-border-0">Simpan</button>
                        <button type="button" t-on-click="restoreFromUrl" t-att-disabled="state.loading" class="tw-flex-1 tw-bg-white tw-border tw-border-gray-300 tw-text-[#b3b3b3] tw-py-[12px] tw-rounded-full tw-font-['Urbanist'] tw-font-medium tw-text-[15px] hover:tw-text-black hover:tw-border-black tw-transition-colors tw-cursor-pointer">Batal</button>
                    </div>
                </div>
            </aside>

            <div id="products_grid" class="col-12 col-lg-9 tw-pl-4">
                <div id="ut-sort-bar" class="tw-bg-white tw-rounded-[14px] tw-h-[64px] tw-px-[24px] tw-flex tw-items-center tw-mb-6 tw-shadow-sm tw-border tw-border-solid tw-border-gray-200">
                    <span class="tw-font-['Urbanist'] tw-font-semibold tw-text-[15px] tw-text-gray-600 tw-mr-6">Urutan</span>
                    <div class="tw-flex tw-gap-[12px]">
                        <div data-sort="terkait" t-att-class="sortClass('terkait')" t-on-click="() => this.changeSort('terkait')">Terkait</div>
                        <div data-sort="terlaris" t-att-class="sortClass('terlaris')" t-on-click="() => this.changeSort('terlaris')">Terlaris</div>
                        <div data-sort="terbaru" t-att-class="sortClass('terbaru')" t-on-click="() => this.changeSort('terbaru')">Terbaru</div>
                        <div data-sort="termurah" t-att-class="sortClass('termurah')" t-on-click="() => this.changeSort('termurah')">Termurah</div>
                        <div data-sort="termahal" t-att-class="sortClass('termahal')" t-on-click="() => this.changeSort('termahal')">Termahal</div>
                    </div>
                </div>

                <div id="ut-shop-results" t-ref="results" t-on-click="onResultsClick" t-att-class="state.loading ? 'tw-opacity-60 tw-transition-opacity' : 'tw-transition-opacity'"></div>
            </div>
        </div>
    </t>
</templates>
