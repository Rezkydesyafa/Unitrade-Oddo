<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="unitrade_product_card" name="UniTrade Reusable Product Card">
        <a t-att-href="ut_card_href"
            t-att-class="'ut-product-card-link ' + ut_card_class"
            itemscope="itemscope"
            itemtype="http://schema.org/Product">
            <div class="tw-p-2">
                <div class="tw-w-full tw-aspect-square tw-rounded-[10px] tw-overflow-hidden tw-bg-gray-100 tw-relative">
                    <img t-attf-src="/web/image/product.template/#{ut_card_product.id}/image_1920"
                        t-att-alt="ut_card_product.name"
                        class="tw-w-full tw-h-full tw-object-cover group-hover:tw-scale-105 tw-transition-transform tw-duration-300"
                        itemprop="image"/>
                    <t t-if="ut_card_product.x_discount_percent">
                        <span class="tw-absolute tw-top-2 tw-left-2 tw-bg-black tw-text-white tw-rounded-full tw-px-2 tw-py-1 tw-font-['Urbanist'] tw-font-bold tw-text-[10px]">
                            -<t t-esc="'{:,.0f}'.format(ut_card_product.x_discount_percent)"/>%
                        </span>
                    </t>
                </div>
            </div>
            <div class="tw-px-3 tw-pb-3 tw-flex tw-flex-col tw-flex-grow">
                <h3 class="tw-font-medium tw-text-[#212529] tw-text-[13px] tw-leading-snug tw-line-clamp-2 tw-mb-1 tw-flex-grow" itemprop="name">
                    <t t-out="ut_card_product.name"/>
                </h3>
                <p class="tw-text-[11px] tw-text-gray-400 tw-mb-2 tw-flex tw-items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-3 tw-h-3 tw-mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <t t-esc="ut_card_product.x_seller_location or ut_card_product.x_item_district or 'Yogyakarta'"/>
                </p>

                <div class="tw-flex tw-justify-between tw-items-center tw-mt-auto">
                    <div class="tw-font-bold tw-text-[#212529] tw-text-[14px]" itemprop="offers" itemscope="itemscope" itemtype="http://schema.org/Offer">
                        <span t-field="ut_card_product.list_price" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                        <span itemprop="price" style="display:none;" t-esc="ut_card_product.list_price"/>
                        <span itemprop="priceCurrency" style="display:none;" t-esc="website.currency_id.name"/>
                    </div>

                    <div class="tw-flex tw-items-center tw-gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-3 tw-h-3 tw-text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                        <span class="tw-text-[11px] tw-text-gray-500">
                            <t t-esc="ut_card_product.rating_avg or 5.0"/>
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </template>
</odoo>
