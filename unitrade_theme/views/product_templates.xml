                <!-- Script: pola identik dengan seller_verification.xml -->
                <script>
                    /* ── Quantity Counter ─── */
                    function utChangeQty(change) {
                        var input = document.querySelector('input[name="add_qty"]');
                        if (!input) return;
                        var currentVal = parseInt(input.value) || 1;
                        var minVal = parseInt(input.getAttribute('data-min')) || 1;
                        var newVal = currentVal + change;
                        if (newVal >= minVal) {
                            input.value = newVal;
                            var event = new Event('change', { bubbles: true });
                            input.dispatchEvent(event);
                        }
                    }

                    /* ── Share Modal (global functions for onclick) ─── */
                    function utShowShareModal() {
                        var modal = document.getElementById('ut-share-modal');
                        if (!modal) return;
                        var urlEl = document.getElementById('ut-share-url-text');
                        if (urlEl) urlEl.innerText = window.location.href;
                        modal.classList.remove('tw-hidden');
                        document.body.style.overflow = 'hidden';
                    }
                    function utHideShareModal() {
                        var modal = document.getElementById('ut-share-modal');
                        if (modal) modal.classList.add('tw-hidden');
                        document.body.style.overflow = '';
                    }
                    function utCopyShareLink(btn) {
                        var url = window.location.href;
                        var icon = btn ? btn.querySelector('i') : null;
                        function flash() {
                            if (!icon) return;
                            var orig = icon.className;
                            icon.className = 'fa fa-check tw-text-2xl';
                            icon.style.color = '#28a745';
                            setTimeout(function() { icon.className = orig; icon.style.color = ''; }, 1500);
                        }
                        if (navigator.clipboard) {
                            navigator.clipboard.writeText(url).then(flash).catch(function() {
                                var ta = document.createElement('textarea');
                                ta.value = url; document.body.appendChild(ta); ta.select();
                                document.execCommand('copy'); document.body.removeChild(ta); flash();
                            });
                        } else {
                            var ta = document.createElement('textarea');
                            ta.value = url; document.body.appendChild(ta); ta.select();
                            document.execCommand('copy'); document.body.removeChild(ta); flash();
                        }
                    }
                    function utShareWhatsApp() {
                        var url = encodeURIComponent(window.location.href);
                        window.open('https://wa.me/?text=' + url, '_blank');
                    }
                    function utWishlistClick(btn) {
                        var pid = btn.getAttribute('data-product-id');
                        if (!pid) return;
                        fetch('/unitrade/wishlist/toggle', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ jsonrpc: '2.0', method: 'call', id: 1, params: { product_id: parseInt(pid, 10) } })
                        }).then(function() {
                            var icon = btn.querySelector('.fa-heart');
                            if (icon) {
                                icon.style.transform = 'scale(1.35)';
                                icon.style.transition = 'transform 0.2s ease';
                                setTimeout(function() { icon.style.transform = 'scale(1)'; }, 300);
                            }
                        }).catch(function(e) { console.error('[UniTrade] Wishlist:', e); });
                    }
                    function utSwitchTab(btn, tabName) {
                        var tabs = ['deskripsi', 'ulasan'];
                        for (var i = 0; i &lt; tabs.length; i++) {
                            var panel = document.getElementById('tab-' + tabs[i]);
                            var tb = document.getElementById('ut-tab-' + tabs[i]);
                            if (panel) panel.style.display = 'none';
                            if (tb) { tb.style.fontWeight = '400'; tb.style.color = '#525252'; tb.style.borderBottomColor = 'transparent'; }
                        }
                        var active = document.getElementById('tab-' + tabName);
                        if (active) active.style.display = 'block';
                        btn.style.fontWeight = '600';
                        btn.style.color = '#212529';
                        btn.style.borderBottomColor = '#212529';
                    }

                    /* ── Gallery thumbnail (IIFE - immediate) ──────── */
                    (function() {
                        var mainImg = document.getElementById('ut-main-image');
                        var thumbs = document.querySelectorAll('.ut-thumb');
                        for (var i = 0; i &lt; thumbs.length; i++) {
                            (function(thumb) {
                                thumb.addEventListener('click', function() {
                                    var src = thumb.getAttribute('data-src');
                                    if (mainImg) {
                                        if (src) {
                                            mainImg.src = src;
                                            for (var j = 0; j &lt; thumbs.length; j++) {
                                                thumbs[j].style.borderColor = 'transparent';
                                            }
                                            thumb.style.borderColor = '#525252';
                                        }
                                    }
                                });
                            })(thumbs[i]);
                        }
                    })();
                </script>

            </section>
        </xpath>

        <xpath expr="//div[@id='product_full_description']" position="replace">
