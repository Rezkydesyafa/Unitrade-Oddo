<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================
         UniTrade Base Layout — extends website.layout
         ============================================ -->

    <!-- Custom Header/Navbar -->
    <template id="unitrade_header" inherit_id="website.layout" name="UniTrade Header">
        <xpath expr="//header" position="replace">
            <header class="tw-w-full tw-z-50 tw-mb-6 md:tw-mb-8 tw-sticky tw-top-0">
                <!-- Top Bar -->
                <div class="tw-w-full tw-bg-[#f5f5f7] tw-h-[40px] tw-flex tw-items-center tw-justify-between tw-px-4 md:tw-px-8 tw-text-[#1d1d1f] tw-text-[13px] tw-font-['Urbanist']">
                    <!-- Left Section -->
                    <div class="tw-flex tw-items-center tw-gap-3">
                        <span class="tw-font-medium">Gratis Ongkir + Diskon 30%</span>
                        <a href="/shop" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] hover:tw-underline tw-transition-colors tw-no-underline tw-font-bold">Belanja Sekarang &amp;rarr;</a>
                        <span class="tw-text-gray-300 tw-mx-1">|</span>
                        <a href="/seller/register" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] hover:tw-underline tw-transition-colors tw-no-underline tw-font-bold">Mulai Berjualan</a>
                    </div>
                    
                    <!-- Right Section -->
                    <div class="tw-hidden md:tw-flex tw-items-center tw-gap-4">
                        <div class="tw-flex tw-items-center tw-gap-3">
                            <a href="/help" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] hover:tw-underline tw-transition-colors tw-no-underline">Bantuan</a>
                            <a href="/contactus" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] hover:tw-underline tw-transition-colors tw-no-underline">Kontak</a>
                            <a href="/tracking" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] hover:tw-underline tw-transition-colors tw-no-underline">Tracking</a>
                        </div>
                        <span class="tw-text-gray-300 tw-mx-1">|</span>
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <span>Ikuti Kami:</span>
                            <a href="#" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] tw-transition-colors tw-ml-1"><i class="fa fa-instagram"></i></a>
                            <a href="#" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] tw-transition-colors tw-ml-1"><i class="fa fa-facebook-square"></i></a>
                            <a href="#" class="tw-text-[#1d1d1f] hover:tw-text-[#000000] tw-transition-colors tw-ml-1"><i class="fa fa-tiktok"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Main Navbar -->
                <div class="tw-pt-4 tw-pb-4 tw-px-4 md:tw-px-8 tw-bg-transparent tw-w-full tw-z-50">
                    <div class="tw-max-w-7xl tw-mx-auto tw-bg-gradient-to-r tw-from-[#1f1f1f]/80 tw-via-[#2a2a2a]/80 tw-to-[#1a1a1a]/80 tw-backdrop-blur-md tw-h-[70px] tw-rounded-[54px] tw-shadow-lg tw-border tw-border-white/10 tw-flex tw-items-center tw-justify-between tw-px-4 md:tw-px-8">
                    <!-- Logo -->
                    <a href="/" class="tw-flex tw-items-center tw-gap-3 tw-no-underline">
                        <img src="/unitrade_theme/static/src/img/logo-unitrade.png" alt="UniTrade Logo" class="tw-h-8 md:tw-h-10 tw-w-auto tw-invert tw-brightness-0"/>
                    </a>

                    <!-- Search Bar -->
                    <div class="tw-hidden md:tw-block tw-flex-1 tw-max-w-3xl tw-mx-8 tw-relative">
                        <form action="/shop" method="get">
                            <input type="text" name="search" class="tw-w-full tw-bg-[#1f1f1f]/40 tw-backdrop-blur-md tw-text-[#fffffc] tw-h-[48px] tw-rounded-[22.5px] tw-pl-5 tw-pr-12 tw-outline-none tw-text-sm tw-border tw-border-white/10 focus:tw-ring-2 focus:tw-ring-white/20 placeholder-gray-400 tw-shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)]" placeholder="Cari produk..."/>
                            <button type="submit" class="tw-absolute tw-right-2 tw-top-1/2 tw--translate-y-1/2 tw-w-9 tw-h-9 tw-bg-[#2a2a2a]/50 tw-backdrop-blur-md tw-rounded-full tw-flex tw-items-center tw-justify-center hover:tw-bg-white/10 tw-transition-colors tw-border tw-border-white/10 tw-cursor-pointer">
                                <svg xmlns="http://www.w3.org/2000/svg" class="tw-h-4 tw-w-4 tw-text-[#fffffc]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </button>
                        </form>
                    </div>

                    <!-- Actions -->
                    <div class="tw-flex tw-items-center tw-gap-3">
                        <t t-if="not user_id._is_public()">
                            <!-- Cart Icon -->
                            <a href="/shop/cart" class="tw-relative tw-flex tw-items-center tw-justify-center tw-w-10 tw-h-10 tw-rounded-full hover:tw-bg-[#fffffc] tw-transition-colors tw-mr-1 tw-text-[#fffffc] hover:tw-text-[#1f1f1f] tw-no-underline tw-group">
                                <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-6 tw-h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="9" cy="21" r="1"></circle>
                                    <circle cx="20" cy="21" r="1"></circle>
                                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                                </svg>
                                <!-- Cart Badge -->
                                <t t-set="website_sale_order" t-value="website.sale_get_order()"/>
                                <t t-if="website_sale_order and website_sale_order.cart_quantity > 0">
                                    <span class="tw-absolute tw-top-0 tw-right-0 tw-bg-red-500 tw-text-[#fffffc] tw-text-[10px] tw-font-bold tw-px-1.5 tw-py-0.5 tw-rounded-full tw-min-w-[16px] tw-text-center tw-transform tw-translate-x-1 tw--translate-y-1" t-esc="website_sale_order.cart_quantity"/>
                                </t>
                            </a>

                            <!-- Logged In State: Avatar Dropdown -->
                            <div class="tw-relative tw-group">
                                <!-- Trigger -->
                                <div class="tw-flex tw-items-center tw-gap-2 tw-cursor-pointer tw-h-full tw-py-2">
                                    <div class="tw-flex tw-items-center tw-justify-center tw-w-[42px] tw-h-[42px] tw-rounded-full tw-bg-gray-800 tw-overflow-hidden tw-border tw-border-white/20">
                                        <img t-attf-src="/web/image?model=res.users&amp;field=avatar_128&amp;id={{user_id.id}}" alt="Avatar" class="tw-w-full tw-h-full tw-object-cover" onerror="this.src='/web/static/img/user_menu_avatar.png'"/>
                                    </div>
                                    <span class="tw-font-['Urbanist'] tw-font-semibold tw-text-[15px] tw-text-[#fffffc] tw-capitalize" t-esc="user_id.name.split(' ')[0]"/>
                                    <!-- Arrow down -->
                                    <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-4 tw-h-4 tw-text-[#fffffc] tw-transition-transform group-hover:tw-rotate-180" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                                
                                <!-- Dropdown -->
                                <div class="tw-absolute tw-right-0 tw-top-full tw-pt-2 tw-invisible tw-opacity-0 group-hover:tw-visible group-hover:tw-opacity-100 tw-transition-all tw-duration-200 tw-z-[999] tw-w-[220px]">
                                    <div class="tw-bg-[#1f1f1f]/80 tw-backdrop-blur-md tw-rounded-2xl tw-shadow-lg tw-py-3 tw-px-2 tw-border tw-border-white/10">
                                        
                                        <a href="/my/home" class="tw-flex tw-items-center tw-gap-3 tw-px-4 tw-py-2.5 tw-rounded-xl hover:tw-bg-white/10 tw-transition-colors tw-group/item tw-no-underline">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-[18px] tw-h-[18px] tw-text-gray-300 group-hover/item:tw-text-[#fffffc]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                            <span class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-gray-300 group-hover/item:tw-text-[#fffffc]">Profile</span>
                                        </a>
                                        
                                        <a href="/my/account" class="tw-flex tw-items-center tw-gap-3 tw-px-4 tw-py-2.5 tw-rounded-xl hover:tw-bg-white/10 tw-transition-colors tw-group/item tw-no-underline tw-mt-1">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-[18px] tw-h-[18px] tw-text-gray-300 group-hover/item:tw-text-[#fffffc]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                                            <span class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-gray-300 group-hover/item:tw-text-[#fffffc]">Pengaturan</span>
                                        </a>
                                        
                                        <t t-if="request.env.user.x_is_seller">
                                            <a href="/seller/dashboard" class="tw-flex tw-items-center tw-gap-3 tw-px-4 tw-py-2.5 tw-rounded-xl hover:tw-bg-white/10 tw-transition-colors tw-group/item tw-no-underline tw-mt-1">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-[18px] tw-h-[18px] tw-text-emerald-400 group-hover/item:tw-text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                                                <span class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-emerald-400 group-hover/item:tw-text-emerald-300">Dashboard Penjual</span>
                                                <span class="tw-ml-auto tw-bg-emerald-500/20 tw-text-emerald-400 tw-text-[10px] tw-px-1.5 tw-py-0.5 tw-rounded-full tw-font-bold">✓</span>
                                            </a>
                                        </t>
                                        <t t-else="">
                                            <a href="/seller-verification" class="tw-flex tw-items-center tw-gap-3 tw-px-4 tw-py-2.5 tw-rounded-xl hover:tw-bg-white/10 tw-transition-colors tw-group/item tw-no-underline tw-mt-1">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-[18px] tw-h-[18px] tw-text-gray-300 group-hover/item:tw-text-[#fffffc]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                                                <span class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-gray-300 group-hover/item:tw-text-[#fffffc]">Jadilah penjual</span>
                                            </a>
                                        </t>
                                        
                                        <div class="tw-h-px tw-bg-white/10 tw-my-2"></div>
                                        
                                        <a href="/web/session/logout?redirect=/" class="tw-flex tw-items-center tw-gap-3 tw-px-4 tw-py-2.5 tw-rounded-xl hover:tw-bg-red-500/20 tw-transition-colors tw-group/item tw-no-underline">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="tw-w-[18px] tw-h-[18px] tw-text-red-400 group-hover/item:tw-text-red-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                                            <span class="tw-font-['Urbanist'] tw-font-medium tw-text-[15px] tw-text-red-400 group-hover/item:tw-text-red-300">Keluar</span>
                                        </a>
                                        
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-else="">
                            <!-- Logged Out State -->
                            <a href="/web/login" class="tw-bg-[#fffffc] tw-text-[#1f1f1f] tw-px-6 tw-py-2.5 tw-rounded-[100px] tw-font-bold tw-text-sm hover:tw-bg-gray-200 tw-transition-colors tw-no-underline tw-shadow-sm">Sign in</a>
                            <a href="/web/signup" class="tw-border tw-border-white/30 tw-text-[#fffffc] tw-px-6 tw-py-2.5 tw-rounded-[100px] tw-font-bold tw-text-sm hover:tw-bg-white/10 tw-transition-colors tw-no-underline">Sign up</a>
                        </t>
                    </div>
                </div>
                </div>
            </header>
        </xpath>
    </template>

    <!-- Google Fonts -->
    <template id="unitrade_google_fonts" inherit_id="website.layout" name="UniTrade Google Fonts">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
            <style>
                body {
                    font-family: 'Urbanist', sans-serif !important;
                    background-color: #ffffff;
                }
            </style>
            <meta name="description" content="UniTrade - Marketplace C2C eksklusif untuk mahasiswa UNISA Yogyakarta. Jual beli aman dengan verifikasi KTM."/>
            <meta name="keywords" content="UniTrade, marketplace, mahasiswa, UNISA, Yogyakarta, jual beli, C2C"/>
        </xpath>
    </template>

    <!-- Footer -->
    <template id="unitrade_footer" inherit_id="website.layout" name="UniTrade Footer Override" active="True">
        <xpath expr="//footer" position="replace">
        <footer class="tw-relative tw-w-full tw-bg-white tw-pt-16 tw-pb-32 tw-overflow-hidden tw-mt-12">
            <!-- Watermark text in background -->
            <div class="tw-absolute tw-bottom-[-5%] tw-left-1/2 tw--translate-x-1/2 tw-w-full tw-text-center tw-pointer-events-none tw-select-none tw-z-0">
                <span class="tw-font-['Urbanist'] tw-font-extrabold tw-text-[12rem] md:tw-text-[18rem] tw-text-gray-200/40 tw-tracking-widest tw-leading-none">UniTrade</span>
            </div>

            <!-- The white card -->
            <div class="tw-relative tw-z-10 tw-max-w-7xl tw-mx-auto tw-px-4 md:tw-px-8">
                <div class="tw-bg-white tw-rounded-[40px] tw-shadow-[0_20px_50px_rgba(0,0,0,0.05)] tw-p-8 md:tw-p-16">
                    <div class="tw-flex tw-flex-col md:tw-flex-row tw-justify-between">
                        <!-- Left Section -->
                        <div class="tw-max-w-md">
                            <div class="tw-flex tw-items-center tw-gap-3 tw-mb-8">
                                <!-- Logo Image -->
                                <img src="/unitrade_theme/static/src/img/logo-unitrade.png" alt="UniTrade Logo" class="tw-h-8 md:tw-h-10 tw-w-auto tw-object-contain"/>
                                <span class="tw-font-['Urbanist'] tw-font-bold tw-text-2xl tw-text-[#212529]">UniTrade</span>
                            </div>
                            <p class="tw-text-gray-600 tw-text-[14px] tw-leading-[1.8] tw-mb-8 tw-m-0">
                                Horem ipsum dolor sit amet, consectetur adipiscing elit. Etiam eu turpis molestie, dictum est a, mattis tellus. Sed dignissim, metus nec fringilla accumsan, risus sem sollicitudin lacus, ut interdum tellus elit sed risus. Maecenas eget condimentum velit, sit amet feugiat lectus.
                            </p>
                            <div class="tw-flex tw-gap-6 tw-items-center tw-mt-8">
                                <!-- Social icons -->
                                <a href="#" class="tw-text-[#212529] hover:tw-text-gray-600 tw-transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.32Z"/>
                                    </svg>
                                </a>
                                <a href="#" class="tw-text-[#212529] hover:tw-text-gray-600 tw-transition-colors">
                                    <!-- WhatsApp Icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                                    </svg>
                                </a>
                                <a href="#" class="tw-text-[#212529] hover:tw-text-gray-600 tw-transition-colors">
                                    <!-- TikTok Icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
                                    </svg>
                                </a>
                                <a href="#" class="tw-text-[#212529] hover:tw-text-gray-600 tw-transition-colors">
                                    <!-- Instagram Icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                                    </svg>
                                </a>
                            </div>
                        </div>

                        <!-- Right Section Links -->
                        <div class="tw-flex tw-gap-24 md:tw-gap-32 tw-mt-10 md:tw-mt-0 md:tw-mr-8">
                            <div>
                                <h4 class="tw-font-semibold tw-text-[#212529] tw-mb-6 tw-text-[15px]">Beli</h4>
                                <ul class="tw-space-y-4 tw-text-sm tw-text-gray-500 tw-p-0 tw-list-none">
                                    <li><a href="/shop" class="hover:tw-text-black tw-transition-colors tw-no-underline tw-text-gray-500">Makanan</a></li>
                                    <li><a href="/shop" class="hover:tw-text-black tw-transition-colors tw-no-underline tw-text-gray-500">Minuman</a></li>
                                    <li><a href="/shop" class="hover:tw-text-black tw-transition-colors tw-no-underline tw-text-gray-500">Pakaian</a></li>
                                </ul>
                            </div>
                            <div>
                                <h4 class="tw-font-semibold tw-text-[#212529] tw-mb-6 tw-text-[15px]">Jual</h4>
                                <ul class="tw-space-y-4 tw-text-sm tw-text-gray-500 tw-p-0 tw-list-none">
                                    <li><a href="/unitrade/seller/register" class="hover:tw-text-black tw-transition-colors tw-no-underline tw-text-gray-500">Daftar Toko</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Horizontal Divider -->
                    <div class="tw-w-full tw-h-px tw-bg-gray-200 tw-mt-12 tw-mb-6"></div>

                    <!-- Bottom Copyright & Links -->
                    <div class="tw-flex tw-flex-col md:tw-flex-row tw-justify-between tw-items-center tw-text-[13px] tw-text-gray-500 tw-gap-4 md:tw-gap-0">
                        <p class="tw-m-0">© 2025 UniTrade. All right reserved.</p>
                        <div class="tw-flex tw-gap-6 tw-items-center">
                            <a href="#" class="hover:tw-text-black tw-transition-colors tw-no-underline tw-text-gray-500">Privacy Policy</a>
                            <a href="#" class="hover:tw-text-black tw-transition-colors tw-no-underline tw-text-gray-500">Terms of Service</a>
                            <a href="#" class="hover:tw-text-black tw-transition-colors tw-no-underline tw-text-gray-500">Cookies Settings</a>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
        </xpath>
    </template>

</odoo>
