<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extend the product template form in backend -->
    <record id="product_template_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.unitrade</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_general']" position="after">
                <group string="UniTrade Marketplace">
                    <field name="x_is_marketplace"/>
                    <field name="x_condition"/>
                    <field name="x_seller_id"/>
                    <field name="x_seller_location"/>
                    <field name="x_seller_latitude"/>
                    <field name="x_seller_longitude"/>
                </group>
                <group string="Detail Produk UniTrade">
                    <field name="x_brand"/>
                    <field name="x_weight_product"/>
                    <field name="x_free_shipping"/>
                </group>
            </xpath>
            <!-- Add specification field in a new notebook page -->
            <xpath expr="//notebook" position="inside">
                <page string="Spesifikasi UniTrade" name="unitrade_specs">
                    <group>
                        <field name="x_specification" widget="html" placeholder="Masukkan spesifikasi teknis produk..."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
